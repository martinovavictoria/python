def bread(func):
    def wrapper():
        return f"хлеб\n{func()}\nхлеб"
    return wrapper

def vegetables(func):
    def wrapper():
        return f"салат\n{func()}"
    return wrapper

def meat(func):
    def wrapper():
        return f"ветчина\n{func()}"
    return wrapper

@bread
@vegetables
@meat
def sandwich():
    return "сыр"

print(sandwich())
